{
  "info": {
    "_postman_id": "fit4110-lab04-notify-b7",
    "name": "FIT4110 Lab04 - Notification Service B7 Contract Tests",
    "description": "Postman Collection cho Phân hệ Dịch vụ Cảnh báo Đa kênh (B7) - team-notify\nChạy trên Docker container hoặc service local.\nFix từ Lab 03: chuẩn hoá status code, ProblemDetails shape, bỏ assertion sai.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate unique IDs per run to avoid deduplication 409 on repeated runs",
          "function uuidv4() {",
          "  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {",
          "    var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);",
          "    return v.toString(16);",
          "  });",
          "}",
          "pm.collectionVariables.set('runEventId',       uuidv4());",
          "pm.collectionVariables.set('runCorrelationId', uuidv4());",
          "pm.collectionVariables.set('runAlertId',       uuidv4());",
          "pm.collectionVariables.set('boundaryEventId',  uuidv4());",
          "pm.collectionVariables.set('boundaryAlertId',  uuidv4());",
          "pm.collectionVariables.set('criticalEventId',  uuidv4());",
          "pm.collectionVariables.set('criticalAlertId',  uuidv4());",
          "pm.collectionVariables.set('latencyEventId',   uuidv4());",
          "pm.collectionVariables.set('latencyAlertId',   uuidv4());",
          "const prefix = pm.environment.get('tracePrefix') || 'fit4110-lab04';",
          "pm.variables.set('traceId', prefix + '-' + Date.now());",
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: pm.variables.get('traceId') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00_Health",
      "item": [
        {
          "name": "GET /health - service is alive",
          "id": "health-check-200",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Health check không cần auth. Phải trả 200 với status=ok và service name."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has status ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'ok');",
                  "});",
                  "pm.test('Response has service name', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('service');",
                  "  pm.expect(json.service).to.be.a('string');",
                  "});",
                  "pm.test('Response has time field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('time');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "POST /alerts - happy path creates alert",
          "id": "create-alert-202",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/alerts",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"]
            },
            "description": "Happy path: gửi alert hợp lệ, phải nhận 202 ACCEPTED với status=PENDING.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{runEventId}}\",\n  \"eventType\": \"core.alert.created\",\n  \"occurredAt\": \"2026-06-08T23:15:00Z\",\n  \"correlationId\": \"{{runCorrelationId}}\",\n  \"source\": \"core-business\",\n  \"data\": {\n    \"alertId\": \"{{runAlertId}}\",\n    \"severity\": \"HIGH\",\n    \"message\": \"Ph\\u00e1t hi\\u1ec7n x\\u00e2m nh\\u1eadp tr\\u00e1i ph\\u00e9p t\\u1ea1i khu v\\u1ef1c c\\u1ed5ng ch\\u00ednh t\\u00f2a IT\",\n    \"targetUserId\": \"SV-12345\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 202 Accepted', function () {",
                  "  pm.response.to.have.status(202);",
                  "});",
                  "pm.test('Response has notificationId', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('notificationId');",
                  "  pm.expect(json.notificationId).to.be.a('string');",
                  "});",
                  "pm.test('Response status is PENDING', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('status', 'PENDING');",
                  "});",
                  "pm.test('Response has acceptedAt timestamp', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('acceptedAt');",
                  "});",
                  "// Lưu notificationId và eventId để dùng ở test duplicate",
                  "if (pm.response.code === 202) {",
                  "  pm.collectionVariables.set('lastNotificationId', pm.response.json().notificationId);",
                  "  pm.collectionVariables.set('lastEventId', pm.collectionVariables.get('runEventId'));",
                  "}"
                ]
              }
            }
          ]
        },
