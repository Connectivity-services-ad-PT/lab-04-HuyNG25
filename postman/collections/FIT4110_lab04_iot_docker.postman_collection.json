          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{aiVisionMockUrl}}/detect",
              "host": ["{{aiVisionMockUrl}}"],
              "path": ["detect"]
            },
            "description": "Consumer-side smoke test: gọi mock của AI Vision. Chỉ có ý nghĩa khi AI Vision mock đang chạy ở aiVisionMockUrl.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"0196fb3d-4ad7-7d1e-9f49-5d5148d2babc\",\n  \"source\": \"core-business\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const env = pm.environment.get('env') || 'mock';",
                  "// Skip nếu env=local vì AI Vision mock không chạy cùng container",
                  "if (env === 'local') {",
                  "  pm.test('Skipped on local: AI Vision mock not co-located with container', function () {",
                  "    pm.expect(true).to.eql(true);",
                  "  });",
                  "} else {",
                  "  pm.test('Consumer receives success from AI Vision mock', function () {",
                  "    pm.expect(pm.response.code).to.eql(200);",
                  "  });",
                  "  pm.test('Consumer can read detection fields', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('detection_id');",
                  "    pm.expect(json).to.have.property('label');",
                  "    pm.expect(json).to.have.property('confidence');",
                  "    pm.expect(json.confidence).to.be.within(0, 1);",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
